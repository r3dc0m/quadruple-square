<div class="auth-container">
  <h1>Register</h1>

  <% if (typeof error !=='undefined' && error) { %>
    <div class="error-message">
      <%= error %>
    </div>
    <% } %>

      <form action="/auth/register" method="POST">
        <div class="form-group">
          <label for="user_name">Name:</label>
          <input type="text" id="user_name" name="user_name" required maxlength="89">
        </div>

        <div class="form-group">
          <label for="user_email">Email:</label>
          <input type="email" id="user_email" name="user_email" required maxlength="144">
        </div>

        <div class="form-group">
          <label for="user_password">Password:</label>
          <input type="password" id="user_password" name="user_password" required minlength="6">
        </div>

        <button type="submit" class="auth-btn">Register</button>
      </form>

      <p>If you know who you are, <a href="/login">click here</a></p>
</div>